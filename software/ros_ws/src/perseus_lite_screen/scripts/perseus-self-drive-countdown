#!/usr/bin/env bash
# Two-minute boot countdown displayed on tty1 (visible on the DP-1 console
# until the screen kiosk grabs DRM master). Invoked as the ExecStartPre of
# perseus-self-drive-boot.service. Abort by stopping that service.

set -u

DURATION=${DURATION:-120}

COLS=$(tput cols 2>/dev/null || echo 80)
LINES=$(tput lines 2>/dev/null || echo 24)

printf '\033[2J\033[H\033[?25l'
trap 'printf "\033[?25h\n"' EXIT

centre() {
    local text="$1"
    local pad=$(( (COLS - ${#text}) / 2 ))
    [ "$pad" -lt 0 ] && pad=0
    printf '%*s%s\n' "$pad" "" "$text"
}

while [ "$DURATION" -ge 0 ]; do
    mins=$((DURATION / 60))
    secs=$((DURATION % 60))

    printf '\033[H'
    vpad=$(( (LINES - 9) / 2 ))
    [ "$vpad" -lt 0 ] && vpad=0
    for ((i=0; i<vpad; i++)); do echo; done

    centre "============================================"
    centre ""
    centre "       Starting Self Driving in..."
    centre ""
    printf '\033[1;36m'
    centre "$(printf '%02d:%02d' "$mins" "$secs")"
    printf '\033[0m'
    centre ""
    centre "(sudo systemctl stop perseus-self-drive-boot to abort)"
    centre "============================================"

    sleep 1
    DURATION=$((DURATION - 1))
done

printf '\033[2J\033[H'
